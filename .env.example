OLLAMA_MODEL=llama3.1:8b

LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

VECTOR_DB=chroma
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5
RERANK_TOP_N=3

# Reranking settings.
# auto first tries a local cross-encoder and falls back to lexical scoring.
RERANKER_PROVIDER=auto
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Evaluation settings.
# EVAL_MAX_QUESTIONS=0 means all questions.
EVAL_SLEEP_SECONDS=0
EVAL_MAX_QUESTIONS=0
EVAL_RESUME=false
