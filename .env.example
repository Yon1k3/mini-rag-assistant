OLLAMA_MODEL=llama3.1:8b

LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

VECTOR_DB=chroma
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5
RERANK_TOP_N=3

# Налаштування reranking
# auto спочатку пробує локальний cross-encoder, а якщо він недоступний
# переходить на простий lexical fallback
RERANKER_PROVIDER=auto
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Налаштування evaluation
# Для Ollama quota немає, тому sleep за замовчуванням 0
EVAL_SLEEP_SECONDS=0
EVAL_MAX_QUESTIONS=0
EVAL_RETRIEVAL_MODES=similarity,hybrid,metadata_filter,query_rewrite,rerank
EVAL_RESUME=true

# true запускає retrieval-only evaluation без генерації відповідей LLM
# Корисно для дуже швидкої перевірки retrieval pipeline
EVAL_RETRIEVAL_ONLY=false
